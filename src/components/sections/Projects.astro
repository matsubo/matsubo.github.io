---
import { Image } from 'astro:assets'
import { Icon } from 'astro-icon/components'
import { useTranslations, type Locale } from '../../i18n/utils'

import aiModeratorImg from '../../images/projects/ai-moderator.png'
import aiTriathlonImg from '../../images/projects/ai-triathlon.png'
import minedsImg from '../../images/projects/mineds.webp'
import gasPlatformImg from '../../images/projects/gas-platform.png'
import recallSystemImg from '../../images/projects/recall-system.png'
import spikeImg from '../../images/projects/spike.webp'
import greeSmartphoneImg from '../../images/projects/gree-smartphone.webp'
import cytaImg from '../../images/projects/cyta.webp'
import terarenImg from '../../images/projects/teraren.webp'
import emojiSpriteImg from '../../images/projects/emoji-sprite.webp'
import covid19DailyImg from '../../images/projects/covid19-daily.webp'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const aiTools = [
  { key: 'moderator', img: aiModeratorImg, alt: 'AI Moderator', href: 'https://ai-moderator.teraren.com/' },
  { key: 'triathlon', img: aiTriathlonImg, alt: 'AI Triathlon Training', href: 'https://triathlon.teraren.com/' },
]

const apiServices = [
  { key: 'postcode', href: 'https://postcode.teraren.com/' },
  { key: 'bank', href: 'https://bank.teraren.com/' },
  { key: 'corporation', href: 'https://corporation.teraren.com/' },
  { key: 'train', href: 'https://train.teraren.com/' },
  { key: 'school', href: 'https://school.teraren.com/' },
  { key: 'seireki', href: 'https://seireki.teraren.com/' },
]

const pastProjects = [
  { key: 'mineds', img: minedsImg, alt: 'Mineds', links: [{ href: 'site', label: 'siteLabel' }] },
  { key: 'gas', img: gasPlatformImg, alt: 'City Gas Retail Platform', links: [] },
  { key: 'recall', img: recallSystemImg, alt: 'Product Recall System', links: [] },
  { key: 'spike', img: spikeImg, alt: 'SPIKE Payment Service', links: [] },
  { key: 'gree', img: greeSmartphoneImg, alt: 'GREE Smartphone Adaptation', links: [{ href: 'blog', label: 'blogLabel' }, { href: 'hatena', label: 'hatenaLabel' }] },
  { key: 'cyta', img: cytaImg, alt: 'Cyta.jp Learning Platform', links: [] },
  { key: 'teraren', img: terarenImg, alt: 'teraren.com Rental Server', links: [] },
  { key: 'emoji', img: emojiSpriteImg, alt: 'Emoji Sprite OSS Library', links: [{ href: 'github', label: 'githubLabel' }] },
  { key: 'covid19', img: covid19DailyImg, alt: 'COVID-19 Case Visualization System', links: [{ href: 'site', label: 'siteLabel' }, { href: 'github', label: 'githubLabel' }] },
  { key: 'sfcCns', img: null, alt: '', links: [{ href: 'site', label: 'siteLabel' }] },
]
---

<section class="py-16 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center gap-3 mb-8">
      <Icon name="heroicons:rocket-launch" class="w-8 h-8 text-primary" />
      <h2 class="text-4xl font-bold">{t('projects.title')}</h2>
    </div>

    <!-- AI Tools -->
    <div class="mb-12">
      <h3 class="text-2xl font-semibold mb-2 flex items-center gap-2">
        <Icon name="heroicons:cpu-chip" class="w-6 h-6 text-secondary" />
        {t('projects.aiTools.title')}
      </h3>
      <p class="text-base-content/70 mb-6">{t('projects.aiTools.subtitle')}</p>
      <div class="grid md:grid-cols-2 gap-6">
        {aiTools.map((tool) => (
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
            <figure>
              <Image src={tool.img} alt={tool.alt} class="w-full h-48 object-cover brightness-75 hover:brightness-100 transition-all duration-300" />
            </figure>
            <div class="card-body">
              <h4 class="card-title">{t(`projects.aiTools.${tool.key}.title`)}</h4>
              <p class="text-sm text-secondary font-semibold">{t(`projects.aiTools.${tool.key}.subtitle`)}</p>
              <p class="text-base-content/80 whitespace-pre-line">{t(`projects.aiTools.${tool.key}.description`)}</p>
              <div class="card-actions justify-end mt-4">
                <a href={tool.href} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-sm">
                  {t(`projects.aiTools.${tool.key}.button`)}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- API Services -->
    <div class="mb-12">
      <h3 class="text-2xl font-semibold mb-2">{t('projects.apiServices.title')}</h3>
      <p class="text-base-content/70 mb-6">{t('projects.apiServices.subtitle')}</p>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {apiServices.map((api) => (
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
            <div class="card-body">
              <h4 class="card-title text-lg">{t(`projects.apiServices.${api.key}.title`)}</h4>
              <p class="text-sm text-secondary font-semibold">{t(`projects.apiServices.${api.key}.subtitle`)}</p>
              <ul class="text-sm space-y-1 mt-2">
                {(t.raw<string[]>(`projects.apiServices.${api.key}.features`) ?? []).map((feature) => (
                  <li>• {feature}</li>
                ))}
              </ul>
              <div class="card-actions justify-end mt-4">
                <a href={api.href} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                  {t(`projects.apiServices.${api.key}.button`)}
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Past Projects -->
    <div>
      <h3 class="text-2xl font-semibold mb-2">{t('projects.pastProjects.title')}</h3>
      <p class="text-base-content/70 mb-6">{t('projects.pastProjects.subtitle')}</p>
      <div class="grid md:grid-cols-2 gap-6">
        {pastProjects.map((proj) => (
          <div class="card bg-base-100 shadow-xl hover:shadow-2xl transition-shadow">
            <figure class="bg-base-300">
              {proj.img ? (
                <Image src={proj.img} alt={proj.alt} class="w-full h-48 object-cover brightness-75 hover:brightness-100 transition-all duration-300" />
              ) : (
                <div class="w-full h-48 flex items-center justify-center bg-gradient-to-br from-primary to-secondary">
                  <span class="text-white text-6xl">📚</span>
                </div>
              )}
            </figure>
            <div class="card-body">
              <h4 class="card-title">{t(`projects.pastProjects.${proj.key}.title`)}</h4>
              <div class="flex flex-wrap gap-2 text-xs mb-2">
                <span class="badge badge-primary">{t(`projects.pastProjects.${proj.key}.period`)}</span>
                <span class="badge badge-secondary">{t(`projects.pastProjects.${proj.key}.company`)}</span>
              </div>
              <p class="text-sm font-semibold text-accent">{t(`projects.pastProjects.${proj.key}.role`)}</p>
              <p class="text-sm text-base-content/80">{t(`projects.pastProjects.${proj.key}.description`)}</p>
              <div class="mt-2">
                <p class="text-xs text-base-content/60"><strong>Tech:</strong> {t(`projects.pastProjects.${proj.key}.tech`)}</p>
              </div>
              {proj.links.length > 0 && (
                <div class="card-actions justify-end mt-4">
                  {proj.links.map((link) => (
                    <a
                      href={t(`projects.pastProjects.${proj.key}.links.${link.href}`)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="btn btn-outline btn-sm"
                    >
                      {t(`projects.pastProjects.${proj.key}.links.${link.label}`)}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
