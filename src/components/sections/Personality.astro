---
import { Icon } from 'astro-icon/components'
import { useTranslations, type Locale } from '../../i18n/utils'
import SectionHeader from '@/components/SectionHeader.astro'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const strengths = ['logical', 'strategic', 'innovation', 'understanding'] as const
---

<section class="py-20 md:py-24 px-4 bg-base-200">
  <div class="max-w-6xl mx-auto">
    <SectionHeader num="03" kicker="PERSONALITY" title={t('personality.title')} />
    <div class="card fm-card card-hover-lift">
      <div class="card-body">
        <h3 class="card-title text-3xl mb-4 flex-col sm:flex-row items-start sm:items-center gap-2 sm:gap-3">
          <span class="badge badge-primary badge-lg whitespace-nowrap">{t('personality.mbti')}</span>
          <span>{t('personality.subtitle')}</span>
        </h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h4 class="text-xl font-semibold mb-3">{t('personality.strengths.title')}</h4>
            <ul class="space-y-2">
              {strengths.map((key) => (
                <li class="flex items-start gap-2">
                  <Icon name="heroicons:sparkles" class="w-5 h-5 text-primary flex-shrink-0 mt-1" />
                  <span>
                    <strong>{t(`personality.strengths.${key}.title`)}</strong> {t(`personality.strengths.${key}.description`)}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h4 class="text-xl font-semibold mb-3">{t('personality.leadership.title')}</h4>
            <p class="mb-4">{t('personality.leadership.description1')}</p>
            <p>{t('personality.leadership.description2')}</p>
          </div>
        </div>
        <div class="mt-6 p-4 bg-base-200 rounded-lg">
          <p class="text-sm italic">
            <strong>{t('personality.note')}</strong> {t('personality.noteText')}{' '}
            <a
              href="https://diary.teraren.com/2025/04/14/mbti/"
              target="_blank"
              rel="noopener noreferrer"
              class="link link-primary"
            >
              {t('personality.fullAnalysis')}
            </a>
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
