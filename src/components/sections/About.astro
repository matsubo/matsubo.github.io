---
import { useTranslations, type Locale } from '../../i18n/utils'
import SectionHeader from '@/components/SectionHeader.astro'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section class="py-20 md:py-24 px-4 bg-base-100">
  <div class="max-w-6xl mx-auto">
    <SectionHeader num="02" kicker="ABOUT" title={t('about.title')} />
    <div class="prose prose-lg max-w-none">
      <p class="text-lg leading-relaxed">{t('about.paragraph1')}</p>
      <p class="text-lg leading-relaxed">{t('about.paragraph2')}</p>
    </div>
  </div>
</section>
