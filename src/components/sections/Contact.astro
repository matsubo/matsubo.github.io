---
import { Icon } from 'astro-icon/components'
import { useTranslations, type Locale } from '../../i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)
---

<section class="py-16 px-4 bg-base-100">
  <div class="max-w-6xl mx-auto text-center">
    <div class="flex items-center justify-center gap-3 mb-8">
      <Icon name="heroicons:envelope" class="w-8 h-8 text-primary" />
      <h2 class="text-4xl font-bold">{t('contact.title')}</h2>
    </div>
    <p class="text-lg text-base-content/70 mb-8">{t('contact.description')}</p>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="https://github.com/matsubo" target="_blank" rel="noopener noreferrer" class="btn btn-primary gap-2">GitHub</a>
      <a href="https://www.linkedin.com/in/yukimatsukura/" target="_blank" rel="noopener noreferrer" class="btn btn-primary gap-2">LinkedIn</a>
      <a href="https://x.com/matsubokkuri" target="_blank" rel="noopener noreferrer" class="btn btn-outline gap-2">X (Twitter)</a>
    </div>
  </div>
</section>
