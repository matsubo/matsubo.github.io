---
import { useTranslations, type Locale } from '../../i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = useTranslations(lang)

const jobs = ['minedia', 'metaps', 'gree'] as const
---

<section class="py-20 md:py-24 px-4">
  <div class="max-w-6xl mx-auto">
    <header class="mb-12">
      <p class="kicker mb-3">05 — EXPERIENCE</p>
      <h2 class="text-4xl md:text-5xl font-bold text-base-content">{t('experience.title')}</h2>
    </header>

    <div class="space-y-5">
      {jobs.map((job) => (
        <article class="card-hover-lift border border-base-content/12 bg-base-200/50 rounded p-6 md:p-8 hover:border-primary/40">
          <div class="flex flex-wrap items-start justify-between gap-4 mb-5">
            <div>
              <h3 class="text-2xl font-bold font-display text-base-content">{t(`experience.${job}.role`)}</h3>
              <p class="text-primary font-semibold mt-1">{t(`experience.${job}.company`)}</p>
            </div>
            <span class="font-mono text-xs uppercase tracking-wider border border-base-content/20 px-3 py-1 text-base-content/70 whitespace-nowrap">
              {t(`experience.${job}.period`)}
            </span>
          </div>
          <ul class="space-y-2.5 text-base-content/75">
            {(t.raw<string[]>(`experience.${job}.items`) ?? []).map((item) => (
              <li class="flex gap-3">
                <span class="text-primary/70 font-mono text-sm mt-1 select-none">—</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
