---
import { localizePath, type Locale } from '../i18n/utils'

interface Props {
  lang: Locale
  /** Logical path without locale prefix, e.g. '/' or '/rails/'. */
  path?: string
  /** Whether this page has per-locale variants. When false (e.g. en-only
   *  tutorials), the other-language link points to that locale's home. */
  localized?: boolean
}

const { lang, path = '/', localized = true } = Astro.props
const options = [
  { code: 'en' as const, label: 'EN' },
  { code: 'ja' as const, label: '日本語' },
]
const hrefFor = (code: Locale) =>
  localized ? localizePath(path, code) : code === 'en' ? path : localizePath('/', code)
---

<div class="flex gap-2">
  {options.map((option) => (
    <a
      href={hrefFor(option.code)}
      class={`btn btn-sm transition-all duration-300 ${lang === option.code ? 'btn-primary' : 'btn-ghost hover:btn-primary'}`}
      aria-current={lang === option.code ? 'true' : undefined}
    >
      {option.label}
    </a>
  ))}
</div>
