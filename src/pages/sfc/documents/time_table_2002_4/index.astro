---
import Layout from '@/layouts/Layout.astro'
---

<Layout
  lang="en"
  path="/sfc/documents/time_table_2002_4/"
  title="時間割 2002年春学期 | Yuki Matsukura"
  description="Keio SFC university class timetable for the spring 2002 semester, listing courses by day and period."
>
  <div class="container mx-auto px-4 py-8">
    <div class="breadcrumbs text-sm mb-8">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/sfc/">University</a></li>
        <li>Timetable 2002/4</li>
      </ul>
    </div>

