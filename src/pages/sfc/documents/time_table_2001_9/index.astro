---
import Layout from '@/layouts/Layout.astro'
---

<Layout
  lang="en"
  path="/sfc/documents/time_table_2001_9/"
  title="時間割 2001年秋学期 | Yuki Matsukura"
  description="Keio SFC university class timetable for the autumn 2001 semester, listing courses by day and period."
>
  <div class="container mx-auto px-4 py-8">
    <div class="breadcrumbs text-sm mb-8">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/sfc/">University</a></li>
        <li>Timetable 2001/9</li>
      </ul>
    </div>

    <h1 class="text-3xl font-bold mb-8">時間割 2001年秋学期</h1>

    <div class="overflow-x-auto">
      <table class="table table-zebra w-full">
        <thead>
          <tr class="bg-primary text-primary-content">
            <th></th>
            <th class="text-center">月</th>
            <th class="text-center">火</th>
            <th class="text-center">水</th>
            <th class="text-center">木</th>
            <th class="text-center">金</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <th class="bg-primary text-primary-content text-center">
              1<br />(9:25〜10:55)
            </th>
            <td class="text-center"></td>
            <td class="text-center"></td>
            <td class="text-center"></td>
            <td class="text-center">
              connectカスタマー<br />戦略定期会議
            </td>
            <td class="text-center"></td>
          </tr>
          <tr>
            <th class="bg-primary text-primary-content text-center">
              2<br />(11:10〜12:40)
            </th>
            <td class="text-center"></td>
            <td class="text-center"></td>
            <td class="text-center">
              英語スキル B(Integrated)<br />(Wesselhoff)<br />λ17
            </td>
            <td class="text-center"></td>
            <td class="text-center">
              英語スキル B(Integrated)<br />(Wesselhoff)<br />ι13
            </td>
          </tr>
          <tr>
            <th class="bg-primary text-primary-content text-center">
              3<br />(13:00〜14:30)
            </th>
            <td class="text-center"></td>
            <td class="text-center">
              connect システム<br />定期会議
            </td>
            <td class="text-center">
              英語スキル B(Oral)<br />(Rand)<br />θ
            </td>
            <td class="text-center">
              統計言語<br />(湯前祥二)<br />ο13
            </td>
            <td class="text-center">
              保健衛生<br />【学期前半】<br />(濱田庸子)<br />κ12
            </td>
          </tr>
          <tr>
            <th class="bg-primary text-primary-content text-center">
              4<br />(14:40〜16:10)
            </th>
            <td class="text-center">
              プレゼンテーション技法<br />(高橋一貢)<br />Ω22
            </td>
            <td class="text-center"></td>
            <td class="text-center">
              体育I(30)<br />(加藤幸司)
            </td>
            <td class="text-center">
              Fisher研究会
            </td>
            <td class="text-center">
              情報処理(30)<br />(小林裕之)<br />ε17
