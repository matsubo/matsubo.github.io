---
import { Icon } from 'astro-icon/components'
import Layout from '@/layouts/Layout.astro'
---

<Layout
  lang="en"
  path="/rails/mac/10_8/"
  title="Ruby on Rails on Mac OS X 10.8 Mountain Lion | Yuki Matsukura"
  description="Ruby on Rails installation guide for Mac OS X 10.8 Mountain Lion, available as downloadable PDF and PowerPoint documents."
>
  <!-- Breadcrumb -->
  <div class="bg-base-200 py-4">
    <div class="container mx-auto px-4">
      <div class="breadcrumbs text-sm">
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/rails/">Ruby on Rails install</a></li>
          <li><a href="/rails/mac/">Mac OS X</a></li>
          <li>Mac OS X 10.8</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 py-12 max-w-4xl">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-5xl font-bold mb-4 flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-12 h-12 text-primary">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
        Mac OS X 10.8 (Mountain Lion)
      </h1>
      <div class="alert alert-info">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="stroke-current shrink-0 w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <span>
          PDFファイルかPowerPointファイルをダウンロードし、参照してください。
        </span>
      </div>
    </div>

    <!-- Download Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 flex items-center gap-3">
        <Icon name="heroicons:arrow-down-tray" class="h-8 w-8 text-primary" />
        ドキュメントをダウンロード
      </h2>

      <div class="space-y-6">
        <!-- PDF Download Card -->
        <div class="card bg-gradient-to-br from-red-500 to-orange-500 text-white shadow-xl">
          <div class="card-body items-center text-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-20 h-20 mb-4">
              <path fill-rule="evenodd" d="M5.625 1.5H9a3.75 3.75 0 013.75 3.75v1.875c0 1.036.84 1.875 1.875 1.875H16.5a3.75 3.75 0 013.75 3.75v7.875c0 1.035-.84 1.875-1.875 1.875H5.625a1.875 1.875 0 01-1.875-1.875V3.375c0-1.036.84-1.875 1.875-1.875zm6.905 9.97a.75.75 0 00-1.06 0l-3 3a.75.75 0 101.06 1.06l1.72-1.72V18a.75.75 0 001.5 0v-4.19l1.72 1.72a.75.75 0 101.06-1.06l-3-3z" clip-rule="evenodd" />
              <path d="M14.25 5.25a5.23 5.23 0 00-1.279-3.434 9.768 9.768 0 016.963 6.963A5.23 5.23 0 0016.5 7.5h-1.875a.375.375 0 01-.375-.375V5.25z" />
            </svg>
            <h3 class="card-title text-2xl mb-2">PDF版</h3>
            <p class="text-lg opacity-90 mb-6">
              PDFリーダーで閲覧可能なドキュメント
            </p>
            <div class="card-actions">
              <a href="/manual_formac_v11.pdf" class="btn btn-lg btn-secondary gap-2" download>
                <Icon name="heroicons:document-text" class="h-6 w-6" />
                PDFをダウンロード
              </a>
            </div>
          </div>
        </div>

        <!-- Divider -->
        <div class="divider text-lg font-semibold">OR</div>

        <!-- PowerPoint Download Card -->
        <div class="card bg-gradient-to-br from-orange-500 to-amber-500 text-white shadow-xl">
          <div class="card-body items-center text-center">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-20 h-20 mb-4">
              <path d="M5.625 1.5c-1.036 0-1.875.84-1.875 1.875v17.25c0 1.035.84 1.875 1.875 1.875h12.75c1.035 0 1.875-.84 1.875-1.875V12.75A3.75 3.75 0 0016.5 9h-1.875a1.875 1.875 0 01-1.875-1.875V5.25A3.75 3.75 0 009 1.5H5.625z" />
              <path d="M12.971 1.816A5.23 5.23 0 0114.25 5.25v1.875c0 .207.168.375.375.375H16.5a5.23 5.23 0 013.434 1.279 9.768 9.768 0 00-6.963-6.963z" />
            </svg>
            <h3 class="card-title text-2xl mb-2">PowerPoint版</h3>
            <p class="text-lg opacity-90 mb-6">
              編集可能なPowerPoint形式のドキュメント
            </p>
            <div class="card-actions">
              <a href="/manual_formac_v11.pptx" class="btn btn-lg btn-accent gap-2" download>
                <Icon name="heroicons:document-text" class="h-6 w-6" />
                PowerPointをダウンロード
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Back Button -->
    <div class="flex justify-start">
      <a href="/rails/mac/" class="btn btn-ghost gap-2">
        <Icon name="heroicons:chevron-left" class="h-5 w-5" />
        戻る
      </a>
    </div>
  </div>
</Layout>
